{
  "name": "gpx2czml",
  "version": "2.0.0",
  "description": "gpx to czml converter module",
  "type": "module",
  "license": "MIT",
  "author": "HanseungYoo (trustyoo86@gmail.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trustyoo86/gpx2czml.git"
  },
  "keywords": ["gpx", "cesiumjs", "3d", "typescript", "czml"],
  "main": "./dist/gpx2czml.cjs",
  "module": "./dist/gpx2czml.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/gpx2czml.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/gpx2czml.js",
      "require": "./dist/gpx2czml.cjs",
      "default": "./dist/gpx2czml.umd.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.5.0"
  }
}
